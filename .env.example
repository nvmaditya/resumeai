# Backend (copy to backend/.env or export)
APP_ENV=local
DATABASE_URL=sqlite:///./data/app.db
JWT_SECRET=dev-only-change-me
JWT_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:5173
DATA_DIR=./data
# SCORE_BACKEND=stub  # instant fake scores — do not use for real eval
SCORE_BACKEND=hiring_agent
# Requires: ollama serve + ollama pull gemma3:4b + vendor deps installed

# Optional absolute path to tectonic. Empty → backend/bin/tectonic.exe then PATH.
TECTONIC_PATH=

# Coach: ollama | openrouter | groq | stub
COACH_BACKEND=ollama
COACH_MODEL=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:4b
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Frontend (copy to frontend/.env)
VITE_API_URL=http://localhost:8000
